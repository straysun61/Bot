# ============================================
# 机器人统一架构 - 配置文件
# ============================================

# 速率限制：每小时可处理的任务数（全局）
PER_HOUR_TASK_LIMIT=100

# ============================================
# 多等级算力配置
# 格式说明：
# _KEY: API密钥
# _TYPE: API类型 (openai-compatible / anthropic-compatible)
# _BASE: API基础地址（可选）
# _MODEL: 模型名称（可选）
# ============================================

# 免费算力
FREE_TIER_KEY=sk-free-key
FREE_TIER_TYPE=openai-compatible
FREE_TIER_BASE=https://api.free.com/v1
FREE_TIER_MODEL=free-model

# 低等级算力
LOW_TIER_KEY=sk-low-key
LOW_TIER_TYPE=openai-compatible
LOW_TIER_BASE=https://api.low.com/v1
LOW_TIER_MODEL=qwen-plus

# 中高等级算力
HIGH_TIER_KEY=sk-high-key
HIGH_TIER_TYPE=openai-compatible
HIGH_TIER_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
HIGH_TIER_MODEL=qwen-plus

# 最高等级算力
ULTRA_TIER_KEY=sk-ant-ultra-key
ULTRA_TIER_TYPE=anthropic-compatible
ULTRA_TIER_BASE=https://api.anthropic.com/v1
ULTRA_TIER_MODEL=claude-sonnet-4-20250514

# ============================================
# 回调与超时配置
# ============================================

# 任务完成回调地址
TASK_CALLBACK_URL=https://callback-server.com/webhook

# 回调鉴权Token
TASK_CALLBACK_TOKEN=your-callback-token

# 任务超时时间（秒），默认600秒（10分钟）
TASK_TIMEOUT_SECONDS=600

# ============================================
# 任务获取模式配置
# ============================================

# 任务获取模式：sse（连接外部SSE） / webhook（本地HTTP服务）
TASK_RECEIVER_MODE=webhook

# SSE模式：外部SSE服务地址
SSE_ENDPOINT=http://scheduler:8080/events
