# ============================================
# DocBot 配置文件
# 复制此文件为 .env 并填入真实值
# ============================================

# ============================================
# 大模型 API 配置（使用百炼 DashScope）
# ============================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
CHAT_MODEL=qwen-plus

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 文件上传配置
# ============================================
MAX_UPLOAD_SIZE_MB=100
SUPPORTED_FILE_TYPES=.pdf,.docx,.doc,.txt,.md,.png,.jpg,.jpeg,.xlsx,.xls

# ============================================
# RAG 配置
# ============================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=10
RETRIEVAL_K=5

# ============================================
# 任务调度配置
# ============================================
PER_HOUR_TASK_LIMIT=100
TASK_TIMEOUT_SECONDS=600
TASK_CALLBACK_URL=
TASK_CALLBACK_TOKEN=
TASK_RECEIVER_MODE=webhook
